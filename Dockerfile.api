FROM golang:1.25-alpine AS build
WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY cmd ./cmd
COPY internal ./internal

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/home-mesh-api ./cmd/server

FROM alpine:3.22
WORKDIR /app

RUN apk add --no-cache iputils net-tools

COPY --from=build /out/home-mesh-api /usr/local/bin/home-mesh-api

ENV HOME_MESH_HTTP_ADDR=:8080
ENV HOME_MESH_DB_PATH=/data/home-mesh.db

VOLUME ["/data"]
EXPOSE 8080

CMD ["home-mesh-api"]
